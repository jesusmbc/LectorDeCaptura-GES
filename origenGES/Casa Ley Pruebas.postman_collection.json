        {
          "name": "suac",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Convertir XML a objeto JSON\r",
                  "let responseJson = xml2Json(pm.response.text());\r",
                  "\r",
                  "// Navegar dentro del SOAP\r",
                  "let comprobante = responseJson[\"soap:Envelope\"]\r",
                  "    [\"soap:Body\"]\r",
                  "    [\"GenerarComprobanteDepositoResponse\"]\r",
                  "    [\"GenerarComprobanteDepositoResult\"]\r",
                  "    [\"ComprobanteDeposito\"];\r",
                  "\r",
                  "// Obtener valores\r",
                  "let folio = comprobante[\"Folio\"];\r",
                  "let codigoBarras = comprobante[\"CodigoBarrasOXXO\"];\r",
                  "\r",
                  "// Guardar variables de entorno\r",
                  "pm.environment.set(\"folio\", folio);\r",
                  "pm.environment.set(\"lineacaptura\", codigoBarras);\r",
                  "\r",
                  "// Validaciones opcionales\r",
                  "pm.test(\"Existe Folio\", function () {\r",
                  "    pm.expect(folio).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Existe CodigoBarrasOXXO\", function () {\r",
                  "    pm.expect(codigoBarras).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "console.log(\"Folio:\", folio);\r",
                  "console.log(\"Codigo:\", codigoBarras);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
